{
  "name": "random-message-action",
  "version": "1.0.10",
  "description": "Github Action to provide a random message to other actions",
  "main": "lib/main.js",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "oxlint src",
    "package": "esbuild src/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.js --sourcemap",
    "all": "bun run build && bun run format && bun run lint && bun run package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnnybenson/random-message-action.git"
  },
  "author": "Johnny Benson <me@j-hnnybens-n.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/johnnybenson/random-message-action/issues"
  },
  "homepage": "https://github.com/johnnybenson/random-message-action#readme",
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "js-yaml": "^4.1.1",
    "oxlint": "^1.67.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
